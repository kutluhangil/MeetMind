{
  "installCommand": "npm install",
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",

  "env": {
    "NEXT_PUBLIC_SUPABASE_URL":      "@next_public_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@next_public_supabase_anon_key",
    "NEXT_PUBLIC_URL":               "@next_public_url",
    "SUPABASE_SERVICE_KEY":          "@supabase_service_key",
    "LEMON_API_KEY":                 "@lemon_api_key",
    "LEMON_STORE_ID":                "@lemon_store_id",
    "LEMON_WEBHOOK_SECRET":          "@lemon_webhook_secret",
    "LEMON_PRO_MONTHLY_USD_ID":      "@lemon_pro_monthly_usd_id",
    "LEMON_PRO_YEARLY_USD_ID":       "@lemon_pro_yearly_usd_id",
    "LEMON_PRO_MONTHLY_TRY_ID":      "@lemon_pro_monthly_try_id",
    "LEMON_PRO_YEARLY_TRY_ID":       "@lemon_pro_yearly_try_id",
    "LEMON_TEAM_MONTHLY_USD_ID":     "@lemon_team_monthly_usd_id",
    "LEMON_TEAM_YEARLY_USD_ID":      "@lemon_team_yearly_usd_id",
    "LEMON_TEAM_MONTHLY_TRY_ID":     "@lemon_team_monthly_try_id",
    "LEMON_TEAM_YEARLY_TRY_ID":      "@lemon_team_yearly_try_id",
    "WORKER_API_SECRET":             "@worker_api_secret",
    "WORKER_INTERNAL_URL":           "@worker_internal_url",
    "RESEND_API_KEY":                "@resend_api_key",
    "RESEND_FROM_EMAIL":             "@resend_from_email",
    "RESEND_FROM_NAME":              "@resend_from_name"
  },

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ],

  "regions": ["iad1"]
}
